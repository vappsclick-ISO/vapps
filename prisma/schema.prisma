generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                       @id @default(uuid())
  name                       String?
  email                      String?                      @unique
  emailVerified              DateTime?
  image                      String?
  password                   String?
  lastActive                 DateTime?                    // Track when user was last active
  phone                      String?
  location                   String?
  bio                        String?
  jobTitle                   String?
  department                 String?
  employeeId                 String?
  reportsTo                  String?
  joinDate                   DateTime?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  accounts                   Account[]
  ownedOrganizations         Organization[]               @relation("OrganizationOwner")
  sessions                   Session[]
  organizations              UserOrganization[]
  notificationDismissals     UserNotificationDismissal[]
  emailChangeRequests        EmailChangeRequest[]
}

model EmailChangeRequest {
  id        String   @id @default(uuid())
  userId    String
  newEmail  String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model UserNotificationDismissal {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  activityId     String
  dismissedAt   DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, activityId])
  @@index([userId, organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  type              String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id          String               @id @default(uuid())
  name        String
  slug        String              @unique
  ownerId     String
  permissions Json?                // Role-based permission matrix: { [key]: { admin, manager, member } }
  createdAt   DateTime             @default(now())
  database    OrgDatabaseInstance?
  owner       User                 @relation("OrganizationOwner", fields: [ownerId], references: [id])
  users       UserOrganization[]
  invitations Invitation[]
}

model UserOrganization {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  role           String       @default("member")
  leadershipTier String?      // Top, Operational, Support - derived from role but stored for easier querying
  jobTitle       String?      // Job title: CEO, CTO, VP, Director, Manager, Supervisor, Team Lead, etc.
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([leadershipTier])
  @@index([jobTitle])
}

model OrgDatabaseInstance {
  id               String       @id @default(uuid())
  organizationId   String       @unique
  dbHost           String
  dbPort           Int
  dbUser           String
  dbPassword       String
  dbName           String
  connectionString String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Invitation {
  id             String       @id @default(uuid())
  token          String       @unique
  organizationId String
  email          String
  name           String?      // User's full name (for display when they accept)
  role           String?      // Role for the invitation (owner, admin, manager, member)
  jobTitle       String?      // Job title: CEO, CTO, VP, Director, Manager, Supervisor, Team Lead, etc.
  siteId         String?      // Site assignment (for Operational/Support leadership)
  processId      String?      // Process assignment (for Operational/Support leadership)
  additionalRoleIds Json?     // Optional additional role IDs (e.g. Auditor) stored as string[]
  status         String       @default("pending") // pending, accepted, expired, cancelled
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  acceptedAt     DateTime?
  invitedBy      String? // User ID who created the invite
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([organizationId])
  @@index([email, status])
  @@index([status, expiresAt])
  @@index([role])
  @@map("invitations")
}
